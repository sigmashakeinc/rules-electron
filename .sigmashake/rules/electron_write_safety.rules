# electron_write_safety.rules
# Technology: electron | Capability: write

rule electron-block-unsafe-patterns {
  enabled true
  priority 90
  severity error
  DENY write
  IF path GLOB "**/*" AND content CONTAINS "UNSAFE_electron_PATTERN"
  MESSAGE "Blocked an unsafe pattern in electron. Use the recommended best practices for 2025/2026."
}

rule electron-force-updated-api {
  enabled true
  priority 80
  severity warning
  ASK write
  IF path GLOB "**/*" AND content CONTAINS "OLD_electron_API"
  MESSAGE "You are using an outdated API for electron. Please upgrade to the newer API."
}
